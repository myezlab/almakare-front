rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ─── User profiles ────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId);

      // On signup the email must match the authenticated identity
      allow create: if isOwner(userId)
        && request.resource.data.email == request.auth.token.email;

      // Users may update their own profile but cannot touch admin-controlled fields
      allow update: if isOwner(userId)
        && !request.resource.data.diff(resource.data)
            .affectedKeys()
            .hasAny(['isDisabled', 'createdAt', 'email']);

      allow delete: if false;

      // ─── Sleep diary ─────────────────────────────────────────────────────
      match /sleepDiary/{date} {
        allow read, write, delete: if isOwner(userId);
      }
    }

    // ─── Notifications ────────────────────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated()
        && request.resource.data.authorId == request.auth.uid;

      // Only the original author may update their notification
      allow update: if isAuthenticated()
        && resource.data.authorId == request.auth.uid;

      allow delete: if false;

      // Read receipts — each user can only manage their own read status
      match /reads/{readerId} {
        allow read, write: if isAuthenticated() && request.auth.uid == readerId;
      }
    }

    // ─── Statistics ───────────────────────────────────────────────────────────
    // Global counters — readable by any signed-in user, written only by Cloud Functions
    match /statistics/{docId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
  }
}
